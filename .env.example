# Copy to .env and fill in.

# --- FREE (default): Google Gemini ---
# Get a free key at https://aistudio.google.com/apikey  (no credit card)
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIza...

# --- PAID (optional): Anthropic Claude (higher quality) ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Optional
# DEFAULT_MODEL=gemini-2.5-flash      # or claude-opus-4-8 for anthropic
DEV_MODE=1                            # cache responses to .cache/ so reruns don't re-call
